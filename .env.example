# LLM provider (OpenAI-compatible endpoint)
# ---
# For enterprise-internal LLM gateways (e.g. company-hosted Copilot backend),
# point base_url at the company endpoint. The provider must speak the
# OpenAI chat completions protocol with tool calling support.
#
# Examples:
#   OPENAI_BASE_URL=https://llm.your-company.com/v1
#   OPENAI_BASE_URL=https://api.openai.com/v1
#   OPENAI_BASE_URL=https://api.anthropic.com/v1   (Anthropic OpenAI-compat shim)
OPENAI_BASE_URL=https://llm.your-company.com/v1
OPENAI_API_KEY=your_api_key_here

# Model name. Must be a model your endpoint serves.
# Examples:
#   gpt-4o, gpt-4-turbo               (OpenAI)
#   claude-3-5-sonnet                  (Anthropic via OpenAI shim)
#   company-internal-model-name        (your company gateway)
OPENAI_MODEL=gpt-4o

# Path to the ai-coding-workflow MCP server's Python executable + args.
# This CLI spawns the MCP server as a subprocess on each invocation.
#
# Example: a venv install of ai-coding-workflow
#   MCP_SERVER_COMMAND=/path/to/ai-coding-workflow/.venv/bin/python
#   MCP_SERVER_ARGS=-m ai_coding_workflow.server
#
# On Windows, use forward slashes or escape backslashes.
MCP_SERVER_COMMAND=/path/to/ai-coding-workflow/.venv/bin/python
MCP_SERVER_ARGS=-m ai_coding_workflow.server

# Optional: pass env vars to the MCP server subprocess.
# These mirror the ai-coding-workflow .env settings. The values here
# are forwarded to the MCP server's process — you can set them once
# in ONE place (here) rather than maintaining ai-coding-workflow's
# .env separately.
MCP_SERVER_ENV_JIRA_BASE_URL=https://your-company.atlassian.net
MCP_SERVER_ENV_JIRA_EMAIL=you@example.com
MCP_SERVER_ENV_JIRA_API_TOKEN=your_jira_token
MCP_SERVER_ENV_JIRA_CLOUD=true
MCP_SERVER_ENV_GITHUB_TOKEN=your_github_token
MCP_SERVER_ENV_GITHUB_DEFAULT_OWNER=your-org
MCP_SERVER_ENV_GITHUB_DEFAULT_REPO=your-repo
# MCP_SERVER_ENV_GITHUB_BASE_URL=https://github.your-company.com/api/v3
MCP_SERVER_ENV_WORKSPACE_PATH=/path/to/your/sandbox/repo

# Agent behavior
# ---
# Hard upper bound on how many ReAct loop turns before forcing stop.
# Prevents runaway loops. Each turn = one LLM call + possibly N tool calls.
AGENT_MAX_TURNS=20

# Logging
# ---
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
