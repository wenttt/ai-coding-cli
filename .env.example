# ai-coding-cli v0.2 Lite — minimal configuration
#
# Copy this file to .env and fill in the REQUIRED section.
# Optional fields have sensible defaults; uncomment only when overriding.
#
# Nested settings use double-underscore: LLM_PRIMARY__BASE_URL maps to
# LLMConfig.primary.base_url. Pydantic-Settings handles the binding.

# ============================================================================
# REQUIRED (8 fields)
# ============================================================================

# Absolute path to the workspace this daemon operates on.
WORKSPACE_PATH=/path/to/your/sandbox/repo

# --- Jira ---
JIRA_BASE_URL=https://jira.your-company.com
# api_token (Atlassian Cloud) or pat (self-hosted Server / Data Center)
JIRA_AUTH_KIND=pat
JIRA_API_TOKEN=

# --- GitHub ---
# For github.com: leave GITHUB_BASE_URL unset.
# For GHES:       set GITHUB_BASE_URL=https://github.your-company.com/api/v3
GITHUB_TOKEN=
# GITHUB_BASE_URL=

# --- LLM (OpenAI-compatible endpoint) ---
LLM_PRIMARY__BASE_URL=https://llm.your-company.com/v1
LLM_PRIMARY__API_KEY=
LLM_PRIMARY__MODEL_NAME=gpt-4o

# ============================================================================
# OPTIONAL (defaults shown in comments)
# ============================================================================

# --- Jira email (only needed when JIRA_AUTH_KIND=api_token) ---
# JIRA_EMAIL=

# --- LLM embedding model (defaults to text-embedding-3-small on the primary endpoint) ---
# LLM_EMBEDDING__BASE_URL=
# LLM_EMBEDDING__API_KEY=
# LLM_EMBEDDING__MODEL_NAME=text-embedding-3-small

# --- Storage ---
# SQLite database location (default: ~/.ai-coding-cli/state.db)
# STORAGE_DB_PATH=

# --- Daemon ---
# DAEMON_HTTP_HOST=127.0.0.1
# DAEMON_HTTP_PORT=8080

# --- Agent ---
# AGENT_MAX_TURNS=20
# AGENT_MAX_TOTAL_TOKENS=200000
# AGENT_TOOL_CALL_TIMEOUT_SECONDS=60
# AGENT_TURN_TIMEOUT_SECONDS=300

# --- Jira polling ---
# JIRA_POLL_ACTIVE_SECONDS=60
# JIRA_POLL_IDLE_SECONDS=300

# --- Guardrail ---
# GUARDRAIL_ACTION_CONFIRMATION_MODE=destructive_only  # never | destructive_only | always
# GUARDRAIL_PROMPT_INJECTION_THRESHOLD=0.8

# --- TLS (corporate proxies with self-signed CA) ---
# REQUESTS_CA_BUNDLE=/path/to/corp-ca.pem
# SSL_CERT_FILE=/path/to/corp-ca.pem

# --- Logging ---
# LOG_LEVEL=INFO
# LOG_FORMAT=json    # json | console

# --- MCP bridges (path to mcp_bridges.yaml; default ~/.config/ai-coding-cli/mcp_bridges.yaml) ---
# MCP_BRIDGES_PATH=
